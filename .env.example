# Copy to .env and fill in real values — never commit .env
FINNHUB_API_KEY=your_finnhub_api_key_here
KINESIS_STREAM_NAME=tickwatch-trades-dev
AWS_REGION=us-east-1
# Optional: leave blank when `aws configure` is set up locally.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional tuning
SYMBOLS=AAPL,MSFT,GOOGL,AMZN,TSLA,META,NVDA,SPY
KINESIS_BATCH_SIZE=100
KINESIS_FLUSH_INTERVAL=1.0
KINESIS_MAX_RETRIES=3
KINESIS_RETRY_BASE_DELAY_MS=100
WS_HEARTBEAT_INTERVAL=30
LOG_LEVEL=INFO
